# Copy this file to secrets.auto.tfvars and fill in real values.
# secrets.auto.tfvars is git-ignored — never commit it.
# Terraform loads *.auto.tfvars automatically, so no -var-file flag is needed.

proxmox_api_url      = "https://<proxmox-host>:8006/"
target_node          = ""
template_id          = 0
storage_pool         = ""
cloud_init_datastore = ""
vm_username          = ""

proxmox_api_token_id     = "terraform@pve!terraform"
proxmox_api_token_secret = ""

vm_password    = ""
ssh_public_key = ""
